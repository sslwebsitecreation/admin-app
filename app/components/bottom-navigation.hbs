<nav class="bottom-nav">
  <button type="button" class="bottom-nav-item {{if this.isIndex 'active'}}" {{on "click" this.goHome}}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
    <span class="bottom-nav-item-label">Home</span>
  </button>

  <button type="button" class="bottom-nav-item {{if this.isProducts 'active'}}" {{on "click" this.goProducts}}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
      <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
      <line x1="12" y1="22.08" x2="12" y2="12"/>
    </svg>
    <span class="bottom-nav-item-label">Products</span>
  </button>

  <button type="button" class="bottom-nav-item {{if this.swappedTab.active 'active'}}" {{on "click" this.goToSwapped}}>
    {{#if this.swappedTab.isYoutube}}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/>
        <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
      </svg>
    {{else if this.swappedTab.isStar}}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    {{else if this.swappedTab.isGrid}}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/>
        <line x1="8" y1="2" x2="8" y2="22"/>
        <line x1="16" y1="2" x2="16" y2="22"/>
        <line x1="2" y1="8" x2="22" y2="8"/>
        <line x1="2" y1="16" x2="22" y2="16"/>
      </svg>
    {{/if}}
    <span class="bottom-nav-item-label">{{this.swappedTab.label}}</span>
  </button>

  <button type="button" class="bottom-nav-item {{if this.isMoreActive 'active'}}" {{on "click" this.toggleSheet}}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="5" cy="12" r="1.5"/>
      <circle cx="12" cy="12" r="1.5"/>
      <circle cx="19" cy="12" r="1.5"/>
    </svg>
    <span class="bottom-nav-item-label">More</span>
  </button>
</nav>

{{#if this.showSheet}}
  <div class="bottom-sheet-overlay" {{on "click" this.closeSheet}}>
    <div class="bottom-sheet" {{on "click" this.stopPropagation}}>
      <div class="bottom-sheet-handle"></div>
      <div class="bottom-sheet-header">
        <h3 class="section-title">More</h3>
      </div>
      <div class="bottom-sheet-body">
        {{#each this.moreTabs as |tab|}}
          <button type="button" class="bottom-sheet-item {{if tab.active 'active'}}" {{on "click" (fn this.selectTab tab)}}>
            <span class="bottom-sheet-item-icon">
              {{#if tab.isYoutube}}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/>
                  <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
                </svg>
              {{else if tab.isStar}}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {{else if tab.isGrid}}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/>
                  <line x1="8" y1="2" x2="8" y2="22"/>
                  <line x1="16" y1="2" x2="16" y2="22"/>
                  <line x1="2" y1="8" x2="22" y2="8"/>
                  <line x1="2" y1="16" x2="22" y2="16"/>
                </svg>
              {{/if}}
            </span>
            <span class="bottom-sheet-item-label">{{tab.label}}</span>
            {{#if tab.active}}
              <span class="bottom-sheet-item-check">&#10003;</span>
            {{/if}}
          </button>
        {{/each}}
      </div>
    </div>
  </div>
{{/if}}
