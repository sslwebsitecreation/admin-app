{{#if (eq @type "stat")}}
  <div class="skeleton skeleton-stat"></div>
{{else if (eq @type "card")}}
  <div class="card p-0 overflow-hidden">
    <div class="skeleton" style="height: 180px; border-radius: 0;"></div>
    <div style="padding: 20px;">
      <div class="skeleton skeleton-title"></div>
      <div class="skeleton skeleton-text"></div>
      <div class="skeleton skeleton-text" style="width: 40%;"></div>
    </div>
  </div>
{{else if (eq @type "table")}}
  <div class="table-container">
    <div style="padding: 16px 24px;">
      <div class="skeleton skeleton-title" style="width: 30%;"></div>
    </div>
    {{#each (repeat 4)}}
      <div class="skeleton-table-row">
        <div class="skeleton skeleton-thumb"></div>
        <div class="skeleton skeleton-table-cell" style="flex: 2;"></div>
        <div class="skeleton skeleton-table-cell" style="flex: 1;"></div>
        <div class="skeleton skeleton-table-cell" style="flex: 0.5;"></div>
        <div class="skeleton skeleton-table-cell" style="flex: 0.5;"></div>
        <div class="skeleton skeleton-table-cell" style="flex: 0.5;"></div>
      </div>
    {{/each}}
  </div>
{{else if (eq @type "product-card")}}
  <div class="product-card">
    <div class="skeleton" style="width: 80px; height: 104px; border-radius: var(--radius-sm); flex-shrink: 0;"></div>
    <div class="product-card-body">
      <div class="skeleton skeleton-text" style="width: 70%;"></div>
      <div class="skeleton skeleton-text" style="width: 40%;"></div>
      <div class="skeleton skeleton-text" style="width: 50%;"></div>
      <div class="product-card-footer" style="margin-top: auto;">
        <div class="skeleton" style="width: 60px; height: 22px; border-radius: 9999px;"></div>
        <div style="display: flex; gap: 4px;">
          <div class="skeleton" style="width: 36px; height: 36px; border-radius: var(--radius-sm);"></div>
          <div class="skeleton" style="width: 36px; height: 36px; border-radius: var(--radius-sm);"></div>
        </div>
      </div>
    </div>
  </div>
{{else}}
  <div class="loading-container">
    <div class="loading-spinner"></div>
  </div>
{{/if}}
