<header class="top-header">
  <div class="top-header-inner">
    <button type="button" class="top-header-logo" {{on "click" this.goHome}}>
      <img src="assets/logo.jpg" alt="" class="top-header-logo-img" />
      <span class="top-header-brand">Riya Sri Silks</span>
    </button>

    <div class="top-header-center desktop-only">
      <div class="search-bar search-bar--has-btn">
        <span class="search-bar-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
          </svg>
        </span>
        <input
          type="text"
          class="search-bar-input"
          placeholder="Search products by name..."
          value={{this.query}}
          {{on "input" this.handleQueryInput}}
          {{on "keydown" this.handleSearchKeydown}}
        />
        <button type="button" class="search-bar-btn" {{on "click" this.handleSearchClick}} aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="top-header-right desktop-only">
      <button
        type="button"
        {{on "click" this.handleSync}}
        disabled={{or this.data.isLoading (not this.canShowSync)}}
        class="top-header-sync"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="top-header-sync-icon">
          <polyline points="23 4 23 10 17 10"/>
          <polyline points="1 20 1 14 7 14"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
        {{#if this.data.isLoading}}
          Syncing...
        {{else}}
          Sync Data
        {{/if}}
        <span class="top-header-sync-remain">({{this.remainingSyncCount}} left)</span>
      </button>
      {{#if this.data.lastSyncedAt}}
        <span class="top-header-sync-info">Last synced: {{format-time this.data.lastSyncedAt}}</span>
      {{/if}}
    </div>

    <div class="mobile-search mobile-only">
      <div class="search-bar search-bar--has-btn">
        <span class="search-bar-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
          </svg>
        </span>
        <input
          type="text"
          class="search-bar-input"
          placeholder="Search products by name..."
          value={{this.query}}
          {{on "input" this.handleQueryInput}}
          {{on "keydown" this.handleSearchKeydown}}
        />
        <button type="button" class="search-bar-btn" {{on "click" this.handleSearchClick}} aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
