<nav class="bg-indigo-600 text-white p-4">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-bold">Saree Admin</h1>
  </div>
</nav>

<div class="flex">
  <aside class="w-64 bg-white shadow-lg min-h-screen">
    <div class="p-4">
      <ul class="space-y-1">
        <li>
          <LinkTo @route="index" class="sidebar-link {{if this.isDashboard 'active'}}">
            Dashboard
          </LinkTo>
        </li>
        <li>
          <LinkTo @route="products" class="sidebar-link {{if this.isProducts 'active'}}">
            Products
          </LinkTo>
        </li>
        <li>
          <LinkTo @route="youtube" class="sidebar-link {{if this.isYoutube 'active'}}">
            YouTube Videos
          </LinkTo>
        </li>
        <li>
          <LinkTo @route="utilities.image-converter" class="sidebar-link {{if this.isUtilities 'active'}}">
            Image Converter
          </LinkTo>
        </li>
        <li class="mt-4 pt-4 border-t">
          <button
            type="button"
            {{on "click" this.handleSync}}
            disabled={{or this.data.isLoading (not this.canShowSync)}}
            class="sidebar-link w-full text-left {{if this.data.isLoading 'opacity-50'}}"
          >
            {{#if this.data.isLoading}}
              Syncing...
            {{else}}
              🔄 Sync ({{this.todaySyncCount}}/{{this.dailySyncLimit}})
            {{/if}}
          </button>
          {{#if this.data.lastSyncedAt}}
            <p class="text-xs text-gray-500 mt-1 px-4">
              Last synced: {{this.data.lastSyncedAt}}
            </p>
          {{/if}}
          {{#if this.canShowClearCache}}
            <button
              type="button"
              {{on "click" this.handleClearCache}}
              class="sidebar-link w-full text-left text-red-600 mt-2"
            >
              🗑️ Clear Cache ({{this.todayClickCount}}/{{this.dailyClearLimit}})
            </button>
          {{else}}
            <p class="text-xs text-gray-500 mt-2 px-4">
              Clear cache limit reached for today
            </p>
          {{/if}}
        </li>
      </ul>
    </div>
  </aside>

  <main class="flex-1 p-6">
    {{outlet}}
  </main>
</div>