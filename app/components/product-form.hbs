<form {{on "submit" this.handleSubmit}} class="space-y-6">

  {{#if this.error}}
    <div class="bg-red-100 border border-red-300 text-red-700 p-4 rounded">
      {{this.error}}
    </div>
  {{/if}}

  {{#if this.successMessage}}
    <div class="bg-green-100 border border-green-300 text-green-700 p-4 rounded">
      {{this.successMessage}}
    </div>
  {{/if}}

  <div>
    <label class="block mb-2 font-semibold">
      Product Name
    </label>

    <input
      type="text"
      class="border p-3 w-full rounded"
      value={{this.name}}
      placeholder="Enter product name"
      {{on "input" this.updateName}}
    />
  </div>

  <div>
    <label class="block mb-2 font-semibold">
      Description
    </label>

    <textarea
      class="border p-3 w-full rounded min-h-[120px]"
      placeholder="Enter description"
      {{on "input" this.updateDesc}}
    >{{this.description}}</textarea>
  </div>

  <div>
    <label class="block mb-2 font-semibold">
      Category
    </label>

    <input
      type="text"
      class="border p-3 w-full rounded"
      value={{this.category}}
      placeholder="Silk, Cotton..."
      {{on "input" this.updateCategory}}
    />
  </div>

  <div>
    <label class="block mb-2 font-semibold">
      Tags
    </label>

    <input
      type="text"
      class="border p-3 w-full rounded"
      value={{this.tags}}
      placeholder="silk,wedding,premium"
      {{on "input" this.updateTags}}
    />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

    <div>
      <label class="block mb-2 font-semibold">
        Original Price
      </label>

      <input
        type="number"
        class="border p-3 w-full rounded"
        value={{this.originalPrice}}
        placeholder="2999"
        {{on "input" this.updatePrice}}
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Discounted Price
      </label>

      <input
        type="number"
        class="border p-3 w-full rounded"
        value={{this.discountedPrice}}
        placeholder="2499"
        {{on "input" this.updateDiscountPrice}}
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Stock Count
      </label>

      <input
        type="number"
        class="border p-3 w-full rounded"
        value={{this.stockCount}}
        placeholder="10"
        {{on "input" this.updateStock}}
      />
    </div>

  </div>

  <hr>

  <div class="space-y-6">

    <div class="flex justify-between items-center">

      <h2 class="text-2xl font-bold">
        Product Images
      </h2>

      <button
        type="button"
        class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded"
        {{on "click" this.addImage}}
      >
        Add Image
      </button>

    </div>

    {{#each this.images as |img index|}}

      <div class="border rounded-xl p-5 space-y-5 bg-white shadow-sm">

        <div class="flex justify-between items-center">

          <h3 class="font-semibold text-lg">
            Image {{add index 1}}
          </h3>

          <button
            type="button"
            data-remove-index={{index}}
            class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded"
            {{on "click" this.removeImage}}
          >
            Remove
          </button>

        </div>

        <div>

          <label class="block mb-2 font-semibold">
            Color
          </label>

          <input
            type="text"
            class="border p-3 w-full rounded"
            value={{img.color}}
            data-color-index={{index}}
            placeholder="Red"
            {{on "input" this.handleColorInput}}
          />

        </div>

        <div class="space-y-3">

          <label class="block font-semibold">
            Upload WEBP Image
          </label>

          <input
            id="file-input-{{index}}"
            type="file"
            accept="image/*"
            class="hidden"
            {{on "change" (fn this.filePicked index)}}
          />

          <button
            type="button"
            class="bg-gray-800 hover:bg-black text-white px-5 py-2 rounded"
            {{on "click" (fn this.chooseFile index)}}
          >
            Choose Image
          </button>

          {{#if (eq img.status "uploading")}}
            <div class="text-blue-600 font-medium">
              Uploading image...
            </div>
          {{/if}}

          {{#if (eq img.status "failed")}}

            <div class="text-red-600 font-medium">
              Upload failed
            </div>

            <button
              type="button"
              class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded"
              {{on "click" (fn this.retryUpload index)}}
            >
              Retry Upload
            </button>

          {{/if}}

          {{#if (eq img.status "uploaded")}}

            <div class="text-green-600 font-medium">
              Upload successful
            </div>

          {{/if}}

        </div>

        <div>

          {{#if img.preview}}

            <img
              src={{img.preview}}
              alt="Preview"
              class="w-48 h-48 object-cover rounded-xl border shadow"
            />

          {{else}}

            <div class="w-48 h-48 border rounded-xl flex items-center justify-center text-gray-400">
              No Image Selected
            </div>

          {{/if}}

        </div>

      </div>

    {{/each}}

  </div>

  <div class="flex gap-4 pt-6">

    <button
      type="submit"
      class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-lg"
      disabled={{this.isSaving}}
    >
      {{if this.isSaving "Saving..." (if this.isEdit "Update Product" "Save Product")}}
    </button>

    <button
      type="button"
      class="bg-gray-300 hover:bg-gray-400 text-black px-8 py-3 rounded-lg"
      {{on "click" this.goBack}}
    >
      Cancel
    </button>

  </div>

</form>