<div class="card max-w-2xl mx-auto">
  <h2 class="text-2xl font-bold mb-6">{{if this.isEdit 'Edit' 'Add'}} Product</h2>

  {{#if this.error}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      {{this.error}}
    </div>
  {{/if}}

  <form {{on "submit" this.handleSubmit}} class="space-y-4">
<div>
      <label class="form-label">Product Images (1200x1600)</label>
      
      <table class="min-w-full divide-y divide-gray-200 mb-4">
        <thead class="bg-gray-50">
          <tr>
            <th class="table-header">#</th>
            <th class="table-header">Image</th>
            <th class="table-header">Color</th>
            <th class="table-header">Action</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          {{#each this.images as |img index|}}
            <tr>
              <td class="table-cell">{{inc index}}</td>
              <td class="table-cell">
                {{#if img.preview}}
                  <img 
                    src={{image-url img.preview}} 
                    alt="Preview" 
                    class="w-20 h-24 object-cover rounded cursor-zoom-in"
                    {{on "click" (fn this.openPreview (image-url img.preview))}}
                  />
                {{else}}
                  <span class="text-gray-400">Uploading...</span>
                {{/if}}
              </td>
              <td class="table-cell">
                <div class="flex items-center gap-2">
                  <input
                    type="color"
                    value={{if img.color img.color "#000000"}}
                    {{on "input" (fn this.handleColorChange index)}}
                    class="w-10 h-10 rounded border border-gray-300 cursor-pointer p-0"
                    style="appearance: none; -webkit-appearance: none; background: transparent;"
                  />
                  <input
                    type="text"
                    value={{img.color}}
                    {{on "input" (fn this.handleColorChange index)}}
                    class="form-input w-24"
                    placeholder="#000000"
                  />
                </div>
              </td>
              <td class="table-cell">
                <button
                  type="button"
                  {{on "click" (fn this.handleRemoveImage index)}}
                  class="btn-danger text-sm"
                >
                  Remove
                </button>
              </td>
            </tr>
          {{/each}}
          <tr>
            <td class="table-cell">{{add this.images.length 1}}</td>
            <td class="table-cell" colspan="4">
              <input
                type="file"
                accept="image/*"
                {{on "change" this.handleAddImage}}
                class="block w-full text-sm text-gray-500 file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700"
              />
            </td>
          </tr>
        </tbody>
      </table>
      
      {{#if this.isUploading}}
        <p class="text-sm text-gray-500">Uploading image...</p>
      {{/if}}
    </div>

    <div>
      <label class="form-label">Name *</label>
      <input
        type="text"
        value={{this.name}}
        {{on "input" this.updateName}}
        class="form-input"
        required
      />
    </div>

    <div>
      <label class="form-label">Category *</label>
      <input
        type="text"
        value={{this.category}}
        {{on "input" this.updateCategory}}
        class="form-input"
        placeholder="e.g., Silk, Cotton, Designer"
        required
      />
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="form-label">Price *</label>
        <input
          type="number"
          value={{this.originalPrice}}
          {{on "input" this.updateOriginalPrice}}
          class="form-input"
          min="0"
          step="0.01"
          required
        />
      </div>
      <div>
        <label class="form-label">Stock Count *</label>
        <input
          type="number"
          value={{this.stockCount}}
          {{on "input" this.updateStockCount}}
          class="form-input"
          min="0"
          required
        />
      </div>
    </div>

    <div>
      <label class="form-label">Description</label>
      <textarea
        value={{this.description}}
        {{on "input" this.updateDescription}}
        class="form-input"
        rows="3"
      ></textarea>
    </div>

    <div class="flex justify-between pt-4">
      <button type="button" {{on "click" this.router.history.back}} class="btn-secondary">
        Cancel
      </button>
      <button
        type="submit"
        class="btn-primary"
        disabled={{or this.isSaving (not this.isValid)}}
      >
        {{#if this.isSaving}}{{if this.isEdit 'Updating...' 'Creating...'}}{{else}}{{if this.isEdit 'Update' 'Create'}} Product{{/if}}
      </button>
    </div>
  </form>

  {{#if this.previewImage}}
    <div 
      class="fixed inset-0 bg-black bg-opacity-90 flex items-center justify-center z-50"
      {{on "click" this.closePreview}}
    >
      <div class="relative max-w-full max-h-full p-4">
        <button
          type="button"
          {{on "click" this.closePreview}}
          class="absolute top-2 right-2 text-white text-3xl font-bold hover:text-gray-300 z-10 p-2"
        >
          &times;
        </button>
        <p class="text-white text-center text-sm mb-2">1200 x 1600</p>
        <img 
          src={{this.previewImage}} 
          alt="Full preview" 
          class="max-w-[1200px] max-h-[1600px] object-contain"
        />
      </div>
    </div>
  {{/if}}
</div>