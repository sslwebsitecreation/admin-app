<div class="form-card">
  <h2>{{if this.isEdit "Edit" "Add"}} Product</h2>

  {{#if this.error}}
    <div class="error-state">{{this.error}}</div>
  {{/if}}

  <form {{on "submit" this.handleSubmit}} class="space-y-4">
    <div>
      <label class="form-label">Product Images (1200x1600)</label>

      <div class="space-y-3 mb-4">
        {{#each this.images as |img idx|}}
          <div class="image-row">
            <div class="image-row-preview">
              {{#if img.preview}}
                <img src={{img.preview}} alt="Preview" />
              {{else}}
                <div class="w-full h-full flex items-center justify-center text-light text-xs">No Image</div>
              {{/if}}
            </div>

            <div class="flex-1 min-w-0">
              <div class="text-xs text-secondary mb-1">{{img.status}}</div>
              {{#if img.key}}
                <div class="text-xs text-secondary">Key: {{img.key}}</div>
              {{/if}}
            </div>

            <div class="flex items-center gap-2">
              <button type="button" {{on "click" this.chooseFile}} class="btn btn-sm btn-secondary">Choose</button>
            </div>

            <div class="flex items-center gap-2">
              <span class="text-xs text-secondary">Color:</span>
              <input type="text" value={{img.color}} data-color-index={{idx}} {{on "input" this.handleColorInput}} class="form-input color-input" placeholder="#000000" />
            </div>

            <button type="button" data-remove-index={{idx}} {{on "click" this.removeImage}} class="btn btn-sm btn-danger">Remove</button>
          </div>
        {{/each}}
      </div>

      <button type="button" {{on "click" this.addImage}} class="btn btn-sm btn-primary">+ Add Image Row</button>
    </div>

    <div>
      <label class="form-label">Name *</label>
      <input type="text" value={{this.name}} {{on "input" this.updateName}} class="form-input" required />
    </div>

    <div>
      <label class="form-label">Category *</label>
      <input type="text" value={{this.category}} {{on "input" this.updateCategory}} class="form-input" required />
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="form-label">Price *</label>
        <input type="number" value={{this.originalPrice}} {{on "input" this.updatePrice}} class="form-input" required />
      </div>
      <div>
        <label class="form-label">Stock *</label>
        <input type="number" value={{this.stockCount}} {{on "input" this.updateStock}} class="form-input" required />
      </div>
    </div>

    <div>
      <label class="form-label">Description</label>
      <textarea value={{this.description}} {{on "input" this.updateDesc}} class="form-input" rows="3"></textarea>
    </div>

    <div class="form-actions">
      <button type="button" {{on "click" this.goBack}} class="btn btn-secondary">Cancel</button>
      <button type="submit" class="btn btn-primary" disabled={{not this.isValid}}>
        {{#if this.isSaving}}Saving...{{else}}{{if this.isEdit "Update" "Create"}} Product{{/if}}
      </button>
    </div>
  </form>

  <input type="file" accept="image/*" id="file-input" {{on "change" this.filePicked}} class="hidden" />
</div>
