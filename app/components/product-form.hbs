<div class="pc-page">
  <div class="pc-container">
    {{! --- Top Header --- }}
    <div class="pc-header">
      <div class="pc-header-left">
        <h1 class="pc-title">{{if this.isEdit "Edit" "Add"}} Product</h1>
        <p class="pc-subtitle">Create and manage saree product details</p>
      </div>
      <div class="pc-header-right">
        <span class="pc-badge">New Product</span>
      </div>
    </div>

    {{#if this.error}}
      <div class="pc-card" style="margin-bottom:16px">
        <span class="pc-error">{{this.error}}</span>
      </div>
    {{/if}}

    <form {{on "submit" this.handleSubmit}}>
      {{! --- Main Card --- }}
      <div class="pc-card">
        {{!-- Product Name --}}
        <div class="pc-card-section">
          <label class="pc-label" for="pc-name">Product Name</label>
          <input
            id="pc-name"
            type="text"
            value={{this.name}}
            {{on "input" this.updateName}}
            class="pc-input"
            placeholder="Kanchipuram Soft Silk Saree"
            required
          />
        </div>

        {{!-- Category --}}
        <div class="pc-card-section">
          <label class="pc-label" for="pc-category">Category</label>
          <div class="pc-dropdown-wrap">
            <div class="pc-input-group">
              <span class="pc-input-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"/>
                  <path d="M21 21l-4.35-4.35"/>
                </svg>
              </span>
              <input
                id="pc-category"
                type="text"
                value={{this.category}}
                {{on "input" this.handleCategoryInput}}
                {{on "blur" this.handleCategoryBlur}}
                {{on "focus" this.handleCategoryFocus}}
                class="pc-input"
                placeholder="Search categories..."
                autocomplete="off"
                required
              />
            </div>
            {{#if this.showCategorySuggestions}}
              <div class="pc-dropdown">
                {{#each this.filteredCategories as |cat|}}
                  <div
                    class="pc-dropdown-item"
                    role="button"
                    {{on "mousedown" (fn this.selectCategory cat)}}
                  >{{cat}}</div>
                {{else}}
                  <div class="pc-dropdown-item">No matches</div>
                {{/each}}
              </div>
            {{/if}}
          </div>
        </div>

        {{!-- Tags --}}
        <div class="pc-card-section">
          <label class="pc-label">Tags</label>
          <div class="pc-dropdown-wrap">
            <div class="pc-tags-wrap" {{on "click" this.focusTagInput}}>
              {{#each this.tags as |tag|}}
                <span class="pc-tag">
                  {{tag}}
                  <button type="button" class="pc-tag-remove" {{on "click" (fn this.removeTag tag)}}>&times;</button>
                </span>
              {{/each}}
              <input
                type="text"
                class="pc-tag-input"
                value={{this.tagInput}}
                {{on "input" this.handleTagInput}}
                {{on "keydown" this.handleTagKeydown}}
                {{on "blur" this.handleTagBlur}}
                placeholder="Type to add tags..."
                autocomplete="off"
              />
            </div>
            {{#if this.showTagSuggestions}}
              <div class="pc-tag-suggestions">
                {{#each this.filteredTags as |tag|}}
                  <div
                    class="pc-tag-suggestion"
                    role="button"
                    {{on "mousedown" (fn this.addTag tag)}}
                  >{{tag}}</div>
                {{/each}}
              </div>
            {{/if}}
          </div>
        </div>

        {{!-- Price --}}
        <div class="pc-card-section">
          <div class="pc-price-row">
            <div>
              <label class="pc-label" for="pc-price">Original Price</label>
              <div class="pc-price-input-wrap">
                <span class="pc-currency">&#8377;</span>
                <input
                  id="pc-price"
                  type="number"
                  value={{this.originalPrice}}
                  {{on "input" this.updatePrice}}
                  class="pc-input"
                  placeholder="2999"
                  required
                />
              </div>
            </div>
            <div>
              <label class="pc-label" for="pc-dprice">Discounted Price</label>
              <div class="pc-price-input-wrap">
                <span class="pc-currency">&#8377;</span>
                <input
                  id="pc-dprice"
                  type="number"
                  value={{this.discountedPrice}}
                  {{on "input" this.updateDiscountedPrice}}
                  class="pc-input"
                  placeholder="2499"
                />
              </div>
            </div>
          </div>
        </div>

        {{!-- Stock --}}
        <div class="pc-card-section">
          <label class="pc-label" for="pc-stock">Stock Count</label>
          <input
            id="pc-stock"
            type="number"
            value={{this.stockCount}}
            {{on "input" this.updateStock}}
            class="pc-input"
            placeholder="10"
            required
          />
        </div>

        {{!-- Description --}}
        <div class="pc-card-section">
          <label class="pc-label" for="pc-desc">Description</label>
          <textarea
            id="pc-desc"
            value={{this.description}}
            {{on "input" this.updateDesc}}
            class="pc-textarea"
            placeholder="Write product details..."
          ></textarea>
        </div>

        {{!-- Variants Section --}}
        <div class="pc-card-section">
          <div class="pc-section-header">
            <div>
              <h3 class="pc-section-title">Variants</h3>
              <p class="pc-section-subtitle">Each row supports one image upload</p>
            </div>
            <button type="button" {{on "click" this.addImage}} class="pc-btn-add-variant">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Add Variant
            </button>
          </div>

          {{#each this.images as |img idx|}}
            <div class="pc-variant-card">
              {{#if this.canRemoveImages}}
                <button type="button" data-remove-index={{idx}} {{on "click" this.removeImage}} class="pc-variant-remove" aria-label="Remove variant">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                  </svg>
                </button>
              {{/if}}

              <div class="pc-variant-row">
                {{!-- Image Upload --}}
                <div class="pc-upload-box {{if img.preview 'pc-upload-box--has-image'}}" role="button" {{on "click" (fn this.chooseVariantImage idx)}}>
                  {{#if img.preview}}
                    <img src={{img.preview}} alt="Variant" />
                    <button type="button" class="pc-upload-remove" {{on "click" (fn this.removeVariantImage idx)}}>&times;</button>
                  {{else if img.isConverting}}
                    <span class="spinner"></span>
                  {{else}}
                    <svg class="pc-upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                      <polyline points="17 8 12 3 7 8"/>
                      <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <span class="pc-upload-text">Upload Image</span>
                  {{/if}}
                </div>

                {{!-- Fields --}}
                <div class="pc-variant-fields">
                  {{!-- Color --}}
                  <div>
                    <label class="pc-label" for="pc-color-{{idx}}">Color</label>
                    <div class="pc-color-row">
                      <input
                        type="color"
                        value={{if img.color img.color "#F97316"}}
                        data-color-index={{idx}}
                        {{on "input" this.handleColorPicked}}
                        class="pc-color-picker"
                        id="pc-color-{{idx}}"
                      />
                      <div class="pc-color-hex">
                        <input
                          type="text"
                          value={{img.colorInput}}
                          data-color-index={{idx}}
                          {{on "input" this.handleColorInput}}
                          {{on "blur" this.handleColorBlur}}
                          class="pc-input"
                          placeholder="#F97316"
                          maxlength="7"
                        />
                      </div>
                      {{#if img.colorError}}
                        <span class="pc-error">{{img.colorError}}</span>
                      {{/if}}
                    </div>
                  </div>

                  {{!-- Variant Name --}}
                  <div class="pc-variant-name-input">
                    <label class="pc-label" for="pc-vname-{{idx}}">Variant Name</label>
                    <input
                      id="pc-vname-{{idx}}"
                      type="text"
                      value={{img.colorName}}
                      data-color-name-index={{idx}}
                      {{on "input" this.handleColorNameInput}}
                      class="pc-input"
                      placeholder="Sunset Orange"
                    />
                  </div>
                </div>
              </div>
            </div>
          {{/each}}
        </div>
      </div>

      {{! --- Bottom Actions --- }}
      <div class="pc-actions-wrap">
        <div class="pc-actions">
          <button type="button" {{on "click" this.goBack}} class="pc-btn pc-btn--secondary">Cancel</button>
          <button type="submit" class="pc-btn pc-btn--primary" disabled={{this.isInvalid}}>
            {{#if this.isSaving}}Saving...{{else}}Save Product{{/if}}
          </button>
        </div>
      </div>
    </form>

    {{! --- Hidden file input --- }}
    <input type="file" accept="image/*" id="file-input" {{on "change" this.filePicked}} class="hidden" />
  </div>
</div>

{{! --- Upload Preview Modal --- }}
{{#if this.modalData}}
  <div class="modal-overlay" {{on "click" this.cancelImage}}>
    <div class="modal-content upload-modal" {{on "click" this.stopPropagation}}>
      <div class="modal-body">
        <div class="modal-preview-side">
          <h4 class="modal-preview-label">Converted WebP</h4>
          <div class="modal-preview-image">
            <img src={{this.modalData.convertedPreviewUrl}} alt="Converted preview" />
          </div>
        </div>
        <div class="modal-info-side">
          <h4 class="modal-preview-label">Original</h4>
          <div class="modal-original-thumb">
            <img src={{this.modalData.originalPreviewUrl}} alt="Original preview" />
          </div>
          <div class="modal-comparison">
            <div class="comparison-row">
              <span class="comparison-label">Original Size</span>
              <span class="comparison-value">{{this.modalData.originalSizeFormatted}}</span>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Converted Size</span>
              <span class="comparison-value comparison-value--green">{{this.modalData.convertedSizeFormatted}}</span>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Compression</span>
              <span class="comparison-value comparison-value--green">{{this.modalData.compressionFormatted}}%</span>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Type</span>
              <span class="comparison-value">{{this.modalData.originalType}} &rarr; WebP</span>
            </div>
            {{#if this.modalData.width}}
              <div class="comparison-row">
                <span class="comparison-label">Resolution</span>
                <span class="comparison-value">{{this.modalData.width}} &times; {{this.modalData.height}}</span>
              </div>
            {{/if}}
          </div>
          <div class="modal-actions">
            <button type="button" {{on "click" this.cancelImage}} class="btn btn-secondary">Cancel</button>
            <button type="button" {{on "click" this.acceptImage}} class="btn btn-primary">Continue</button>
          </div>
        </div>
      </div>
    </div>
  </div>
{{/if}}