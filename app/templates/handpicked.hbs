{{#if @model.error}}
  <div class="error-state">{{@model.error}}</div>
{{/if}}

<div class="page-header">
  <div>
    <h1 class="page-title">Handpicked Sarees</h1>
    <p class="mt-1" style="font-size: 14px; color: var(--text-secondary);">Max 5 — curated selection for featured display</p>
  </div>
</div>

{{#if @model.loading}}
  <div class="grid gap-4">
    {{#each (repeat 3)}}
      <LoadingSkeleton @type="product-card" />
    {{/each}}
    {{#each (repeat 2)}}
      <div class="skeleton" style="height: 160px; border-radius: var(--radius-2xl);"></div>
    {{/each}}
  </div>
{{else}}
  <div class="handpicked-grid">
    {{#each (repeat 5) as |_ idx|}}
      {{#if (get @model.handpicked idx)}}
        {{#let (get @model.handpicked idx) as |product|}}
          <div class="handpicked-slot">
            <div class="product-card card-hover">
              <div>
                {{#if product.images.length}}
                  <img
                    src={{image-url product.images.firstObject.key}}
                    alt={{product.name}}
                    class="product-card-image"
                  />
                {{else}}
                  <div class="product-card-image flex items-center justify-center" style="background: var(--bg-main);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-light)" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {{/if}}
              </div>
              <div class="product-card-body">
                <p class="product-card-name">{{product.name}}</p>
                <p class="product-card-category">{{product.category}}</p>
                <p class="product-card-price">₹{{product.original_price}}</p>
                <div class="product-card-footer">
                  <StockBadge @count={{product.stock_count}} />
                </div>
              </div>
            </div>
          </div>
        {{/let}}
      {{else}}
        <EmptySlot />
      {{/if}}
    {{/each}}
  </div>
{{/if}}
