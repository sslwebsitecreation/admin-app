{{#if @model.error}}
  <div class="error-state">{{@model.error}}</div>
{{/if}}

<PageHeader @title="All Videos" @buttonText="Add Video" @buttonRoute="youtube.new" />

{{#if @model.loading}}
  <div class="grid grid-cols-1 desktop-only:grid-cols-3 gap-6">
    <LoadingSkeleton @type="card" />
    <LoadingSkeleton @type="card" />
    <LoadingSkeleton @type="card" />
  </div>
{{else if @model.videos}}
  {{!-- Desktop Table --}}
  <div class="table-container desktop-only fade-in">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Thumbnail</th>
            <th>Video URL</th>
            <th>Linked Sarees</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each @model.videos as |video idx|}}
            <tr>
              <td class="text-secondary">{{add idx 1}}</td>
              <td>
                {{#if video.link}}
                  <img
                    src="https://img.youtube.com/vi/{{video.link}}/mqdefault.jpg"
                    alt={{video.title}}
                    class="thumbnail"
                    onerror="this.src='data:image/svg+xml,%253Csvg xmlns=%2522http://www.w3.org/2000/svg%2522 width=%2522120%2522 height=%252290%2522 fill=%2522%2523f3e4d8%2522%253E%253Crect width=%2522120%2522 height=%252290%2522/%253E%253C/svg%253E'"
                  />
                {{else}}
                  <div class="thumbnail flex items-center justify-center" style="background: var(--bg-main);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--text-light)" stroke-width="1.5">
                      <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/>
                    </svg>
                  </div>
                {{/if}}
              </td>
              <td>
                <a href="https://www.youtube.com/watch?v={{video.link}}" target="_blank" rel="noopener noreferrer" class="text-primary font-medium">
                  {{if video.title video.title video.link}}
                </a>
              </td>
              <td>
                <span class="badge badge-count">
                  {{length-of video.product_ids}} linked
                </span>
              </td>
              <td>
                <div class="flex gap-2">
                  <LinkTo @route="youtube.edit" @model={{video.id}} class="btn-icon" aria-label="Edit">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                      <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                  </LinkTo>
                  <button type="button" {{on "click" (fn this.deleteVideo video.id)}} class="btn-icon danger" aria-label="Delete">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"/>
                      <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                    </svg>
                  </button>
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Mobile Cards --}}
  <div class="mobile-only grid gap-4 fade-in">
    {{#each @model.videos as |video|}}
      <VideoCard @video={{video}} @onDelete={{this.deleteVideo}} />
    {{/each}}
  </div>
{{else}}
  <div class="empty-state">
    <div class="empty-state-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/>
        <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
      </svg>
    </div>
    <h3 class="empty-state-title">No videos yet</h3>
    <p class="empty-state-text">Add your first YouTube video showcasing your sarees.</p>
    <LinkTo @route="youtube.new" class="btn btn-primary mt-6">Add Video</LinkTo>
  </div>
{{/if}}
