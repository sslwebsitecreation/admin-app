<div class="card">
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold">YouTube Videos</h2>
    <LinkTo @route="youtube.new" class="btn-primary">Add Video</LinkTo>
  </div>

  {{#if @model.error}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      {{@model.error}}
    </div>
  {{/if}}

  {{#if @model.videos}}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {{#each @model.videos as |video|}}
        <div class="bg-white rounded-xl shadow-sm overflow-hidden">
          <div class="aspect-video">
            <iframe
              src="https://www.youtube.com/embed/{{video.link}}"
              class="w-full h-full"
              frameborder="0"
              allowfullscreen
            ></iframe>
          </div>
          <div class="p-4">
            <h3 class="font-medium text-gray-900 truncate">{{video.title}}</h3>
            {{#if video.description}}
              <p class="text-sm text-gray-500 mt-1 line-clamp-2">{{video.description}}</p>
            {{/if}}
            <div class="mt-4 flex justify-between items-center">
              <span class="text-xs text-gray-400">ID: {{video.id}}</span>
              <div class="flex gap-2">
                <LinkTo @route="youtube.edit" @model={{video.id}} class="btn-secondary text-sm py-1 px-3">
                  Edit
                </LinkTo>
                <button type="button" {{on "click" (fn this.deleteVideo video.id)}} class="btn-danger text-sm py-1 px-3">
                  Delete
                </button>
              </div>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="text-gray-500 text-center py-8">No videos yet. <LinkTo @route="youtube.new" class="text-indigo-600 hover:underline">Add one</LinkTo></p>
  {{/if}}
</div>