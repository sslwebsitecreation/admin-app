{{#if @model.error}}
  <div class="error-state">{{@model.error}}</div>
{{/if}}

{{#if @model.loading}}
  <div class="grid gap-6">
    <div class="skeleton skeleton-title" style="width: 300px; height: 40px;"></div>
    <div class="grid grid-cols-2 gap-6">
      <div class="skeleton skeleton-stat"></div>
      <div class="skeleton skeleton-stat"></div>
    </div>
  </div>
{{else}}
  <div class="welcome-section fade-in">
    <div>
      <h1 class="welcome-title">Welcome back! 👋</h1>
      <p class="welcome-subtitle">Here's what's happening with your store.</p>
    </div>
    <a href="https://riyasrisilks.com" target="_blank" rel="noopener noreferrer" class="visit-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
        <polyline points="15 3 21 3 21 9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
      Visit Website
    </a>
  </div>

  <div class="grid grid-cols-2 gap-6 mb-8">
    <div class="fade-in slide-up stagger-1">
      <StatCard @icon="products" @label="Total Products" @value={{@model.products.length}} />
    </div>
    <div class="fade-in slide-up stagger-2">
      <StatCard @icon="videos" @label="Total YouTube Videos" @value={{@model.youtube.length}} />
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div class="fade-in slide-up stagger-3">
      <ActionCard @icon="product" @title="Add Product" @route="products.new" />
    </div>
    <div class="fade-in slide-up stagger-4">
      <ActionCard @icon="video" @title="Add YouTube Video" @route="youtube.new" />
    </div>
  </div>

  <div class="mobile-only mobile-actions">
    <button
      type="button"
      {{on "click" this.handleSync}}
      disabled={{or this.data.isLoading (not this.canShowSync)}}
      class="action-card"
    >
      <div class="action-card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 4 23 10 17 10"/>
          <polyline points="1 20 1 14 7 14"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
      </div>
      <span class="action-card-title">
        {{if this.data.isLoading "Syncing..." "Sync Data"}}
      </span>
    </button>
    <button
      type="button"
      {{on "click" this.handleClearCache}}
      disabled={{not this.canShowClearCache}}
      class="action-card"
    >
      <div class="action-card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
        </svg>
      </div>
      <span class="action-card-title">Clear Cache</span>
    </button>
    <button
      type="button"
      class="action-card"
      onclick="window.location.href='/'"
    >
      <div class="action-card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      </div>
      <span class="action-card-title">Logout</span>
    </button>
  </div>
{{/if}}
