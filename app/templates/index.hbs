<div class="card">
  <h2 class="text-2xl font-bold mb-4">Dashboard</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="text-gray-500 text-sm uppercase tracking-wide">Total Products</h3>
      <p class="text-4xl font-bold text-indigo-600">{{@model.products.length}}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h3 class="text-gray-500 text-sm uppercase tracking-wide">YouTube Videos</h3>
      <p class="text-4xl font-bold text-indigo-600">{{@model.youtube.length}}</p>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
    <LinkTo @route="products.new" class="btn-primary text-center">Add New Product</LinkTo>
    <LinkTo @route="youtube.new" class="btn-primary text-center">Add YouTube Video</LinkTo>
  </div>
</div>