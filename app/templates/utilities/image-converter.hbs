<div class="card">
  <h2 class="section-title mb-4">Image Converter</h2>
  <p class="text-secondary mb-6">Convert any image to WebP with custom dimensions and quality</p>

  {{#if this.error}}
    <div class="error-state">{{this.error}}</div>
  {{/if}}

  <div class="grid grid-cols-1 desktop:grid-cols-2 gap-6">
    <div>
      <h3 class="font-semibold mb-3">1. Select Image</h3>
      <input
        id="ic-file-input"
        type="file"
        accept="image/*"
        {{on "change" this.handleFileSelect}}
        class="block w-full text-sm"
        style="color: var(--text-secondary);"
      />

      {{#if this.fileInfo}}
        <div class="mt-4 p-4" style="background: var(--bg-main); border-radius: var(--radius-sm);">
          <h4 class="font-semibold text-sm mb-2" style="color: var(--text-secondary);">Original File Info:</h4>
          <div class="text-sm" style="color: var(--text-secondary);">
            <p class="mb-1"><strong>Name:</strong> {{this.fileInfo.name}}</p>
            <p class="mb-1"><strong>Size:</strong> {{this.fileInfo.size}}</p>
            <p class="mb-1"><strong>Dimensions:</strong> {{this.fileInfo.width}} x {{this.fileInfo.height}}</p>
            <p class="mb-1"><strong>Format:</strong> {{this.fileInfo.format}}</p>
          </div>
        </div>
      {{/if}}

      {{#if this.originalPreview}}
        <div class="mt-4">
          <h4 class="font-semibold text-sm mb-2" style="color: var(--text-secondary);">Original Preview:</h4>
          <div style="border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg-main); max-height: 300px; overflow-y: auto;">
            <img src={{this.originalPreview}} alt="Original" class="w-full" />
          </div>
          <button
            type="button"
            {{on "click" this.handleViewOriginalFull}}
            class="btn btn-sm btn-ghost mt-2"
            style="color: var(--primary);"
          >
            View Full Size
          </button>
        </div>
      {{/if}}
    </div>

    <div>
      <h3 class="font-semibold mb-3">2. Settings</h3>

      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="form-label">Width (px) — Recommended: 1200</label>
            <input
              type="number"
              value={{this.width}}
              {{on "input" (fn this.handleDimensionChange "width")}}
              class="form-input"
              min="100"
              max="4000"
            />
          </div>
          <div>
            <label class="form-label">Height (px) — Recommended: 1600</label>
            <input
              type="number"
              value={{this.height}}
              {{on "input" (fn this.handleDimensionChange "height")}}
              class="form-input"
              min="100"
              max="4000"
            />
          </div>
        </div>

        <div>
          <label class="form-label">Quality: {{this.quality}}%</label>
          <input
            type="range"
            min="10"
            max="100"
            value={{this.quality}}
            {{on "input" this.handleQualityChange}}
            class="w-full"
            style="height: 8px; background: var(--border); border-radius: 4px; outline: none; -webkit-appearance: none; appearance: none;"
          />
          <div class="flex justify-between text-xs mt-1" style="color: var(--text-light);">
            <span>Smaller file</span>
            <span>Better quality</span>
          </div>
        </div>

        <div>
          <label class="form-label">Target Output Size (KB) — Recommended: 200, Max: 400</label>
          <input
            type="number"
            value={{this.targetSizeKB}}
            {{on "input" this.handleTargetSizeChange}}
            class="form-input"
            min="50"
            max="400"
          />
          <p class="text-xs mt-1" style="color: var(--text-light);">Will reduce quality to meet this size if needed</p>
        </div>

        <button
          type="button"
          {{on "click" this.handleConvert}}
          disabled={{or this.isProcessing (not this.selectedFile)}}
          class="btn btn-primary w-full"
        >
          {{#if this.isProcessing}}Processing...{{else}}Convert to WebP{{/if}}
        </button>
      </div>

      {{#if this.convertedPreview}}
        <div class="mt-6">
          <h4 class="font-semibold text-sm mb-2" style="color: var(--text-secondary);">
            Converted: {{this.width}}x{{this.height}} ({{this.convertedSize}})
          </h4>
          <img src={{this.convertedPreview}} alt="Converted" class="w-full h-auto" style="border-radius: var(--radius-sm); border: 1px solid var(--border); max-height: 300px;" />

          <div class="mt-4 flex gap-2">
            <button
              type="button"
              {{on "click" this.handleDownload}}
              class="btn btn-primary flex-1"
            >
              Download WebP
            </button>
            <button
              type="button"
              {{on "click" this.handleViewExactSize}}
              class="btn btn-secondary"
            >
              View Exact Size
            </button>
            <button
              type="button"
              {{on "click" this.handleReset}}
              class="btn btn-secondary"
            >
              Reset
            </button>
          </div>
        </div>
      {{/if}}
    </div>
  </div>
</div>

{{#if this.showExactPreview}}
  <div
    style="position: fixed; top: 0; right: 0; bottom: 0; left: 0; z-index: 9999; overflow: auto; background: rgba(0,0,0,0.9);"
    {{on "click" this.handleCloseExactPreview}}
  >
    <div style="display: flex; justify-content: center; align-items: flex-start; min-height: 100vh; padding: 32px;" {{on "click" this.stopPropagation}}>
      <div style="position: relative;">
        <button
          type="button"
          {{on "click" this.handleCloseExactPreview}}
          style="position: absolute; top: -8px; right: -8px; color: white; font-size: 30px; font-weight: bold; z-index: 50; background: black; border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; line-height: 1;"
        >
          &times;
        </button>
        <p style="color: white; text-align: center; font-size: 14px; margin-bottom: 8px;">{{this.width}} x {{this.height}} ({{this.convertedSize}})</p>
        <div style="background: white; box-shadow: var(--shadow-card);">
          <img src={{this.convertedPreview}} alt="Exact Preview" style="max-width: 90vw; max-height: 80vh; display: block; margin: auto;" />
        </div>
      </div>
    </div>
  </div>
{{/if}}

{{#if this.showOriginalFull}}
  <div
    style="position: fixed; top: 0; right: 0; bottom: 0; left: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.9);"
    {{on "click" this.handleCloseOriginalFull}}
  >
    <div style="position: relative; max-width: 100%; max-height: 100%; padding: 16px; overflow: auto;" {{on "click" this.stopPropagation}}>
      <button
        type="button"
        {{on "click" this.handleCloseOriginalFull}}
        style="position: absolute; top: 8px; right: 8px; color: white; font-size: 30px; font-weight: bold; z-index: 10; padding: 8px; border: none; background: none; cursor: pointer; line-height: 1;"
      >
        &times;
      </button>
      {{#if this.fileInfo}}
        <p style="color: white; text-align: center; font-size: 14px; margin-bottom: 8px;">Original: {{this.fileInfo.width}} x {{this.fileInfo.height}}</p>
      {{/if}}
      <img src={{this.originalPreview}} alt="Original Full" style="max-width: 100%; max-height: 80vh;" />
    </div>
  </div>
{{/if}}
